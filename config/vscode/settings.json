{
   "editor.fontFamily": "InconsolataLGC Nerd Font",
  //  "editor.fontFamily": "'Inconsolata-g', 'monospace', monospace, 'Droid Sans Fallback'ZZ",
  // "editor.fontFamily": "'RobotoMono Nerd Font', 'monospace', monospace, 'Droid Sans Fallback'",
  "editor.fontSize": 11,
  "editor.lineHeight": 2,
  "window.zoomLevel": 0.65,
  "update.showReleaseNotes": false,
  // minimal
  //"workbench.statusBar.visible": false,
  //"workbench.activityBar.visible": false,
  "editor.minimap.enabled": false,
  "breadcrumbs.enabled": false,
  //"window.menuBarVisibility": "toggle",
  // "editor.scrollbar.horizontal": "hidden",
  // "editor.scrollbar.horizontalScrollbarSize": 6,
  // "editor.scrollbar.vertical": "hidden",kkk
  // "editor.scrollbar.verticalScrollbarSize": 6,
  // disable git
  // "git.decorations.enabled": false,
  // "git.enabled": false,
  // "git.path": null,
  // "git.autofetch": false,
  "workbench.colorCustomizations": {
    // // "editorCursor.foreground": "#ffff00",
    // "editorCursor.foreground": "#EBCB8B",
    "terminalCursor.foreground": "#ffff00",
  },
  "editor.cursorBlinking": "expand",
  "workbench.settings.useSplitJSON": true,
  "extensions.ignoreRecommendations": true,
  "diffEditor.wordWrap": "on",
  "editor.acceptSuggestionOnEnter": "off",
  "editor.renderLineHighlight": "all",
  // "editor.parameterHints.enabled": false,
  "files.trimFinalNewlines": true,
  "window.restoreWindows": "none",
  "editor.occurrencesHighlight": "off",
  "glassit.alpha": 250,
  // tabs and spaces
  "editor.tabSize": 2,
  "editor.detectIndentation": false,
  "[typescript]": {
    "editor.tabSize": 2
  },
  "[html]": {
    "editor.tabSize": 2
  },
  "[css]": {
    "editor.tabSize": 2
  },
  "[scss]": {
    "editor.tabSize": 2
  },
  "[python]": {
    "editor.tabSize": 4
  },

  //tailwind
  "css.validate": false,
  "tailwindCSS.includeLanguages": {
    "html": "html",
    "javascript": "javascript",
    "css": "css"
  },
  "editor.quickSuggestions": {
    "strings": true
  },
  // emmet
  //emmet inside react jsx
  // "emmet.includeLanguages": {
  //     "javascript": "javascriptreact"
  // },
  // "emmet.excludeLanguages": [
  //     "markdown"
  // ],
  // vim
  // "vscode-neovim.neovimExecutablePaths.linux": "/usr/bin/nvim",
  "security.workspace.trust.untrustedFiles": "open",
  // "terminal.external.linuxExec": "kitty",
  // autocmp off
  // "editor.quickSuggestionsDelay": 10000,
  // "editor.quickSuggestions": false,
  // "editor.suggest.showTypeParameters": false,
  "editor.hover.enabled": "off",
  // "diffEditor.ignoreTrimWhitespace": false,
  // java
  // "java.completion.enabled": false,
  //"java.configuration.checkProjectSettingsExclusions": false,

  "vim.easymotion": true,
  "vim.incsearch": true,
  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": true,
  "vim.hlsearch": true,
  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "k"],
      "after": ["<Esc>"]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "d"],
      "after": ["d", "d"]
    },
    {
      "before": ["<C-n>"],
      "commands": [":nohl"]
    }
  ],
  "vim.handleKeys": {
    "<C-a>": false,
    "<C-f>": false
  },
  "explorer.confirmDragAndDrop": false,
  "oneDarkPro.vivid": false,

  // "[javascript]": {
  //   "editor.defaultFormatter": "esbenp.prettier-vscode"
  // },
  // Set the default
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  // Enable per-language
  "[javascript]": {
    "editor.formatOnSave": true
  },
  "workbench.iconTheme": "material-icon-theme",
  "workbench.sideBar.location": "right",
  "glassit-linux.opacity": 95,
  // "window.titleBarStyle": "custom",
  "files.autoSave": "afterDelay",
  "editor.linkedEditing": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "workbench.startupEditor": "none",
  "redhat.telemetry.enabled": false,
  "dev.containers.dockerPath": "podman",
  "workbench.activityBar.location": "top"
}
